<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OTP Verification</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      line-height: 1.6;
      margin: 0;
      padding: 20px;
      background-color: #f5f5f5;
    }

    .email-wrapper {
      max-width: 700px;
      margin: 0 auto;
      background-color: white;
      border: 1px solid #ddd;
      border-radius: 8px;
      overflow: hidden;
    }

    .email-header {
      background-color: white;
      padding: 20px;
      border-bottom: 2px solid #ddd;
      text-align: center;
    }

    .email-header img {
      width: 150px;
      height: auto;
    }

    .main-content {
      padding: 20px;
    }

    .greeting {
      font-size: 14px;
      margin-bottom: 20px;
      color: #333;
    }

    .otp-box {
      background-color: #e7f3ff;
      border: 1px solid #b3d9ff;
      border-radius: 4px;
      padding: 20px;
      font-size: 22px;
      font-weight: bold;
      text-align: center;
      margin: 20px 0;
      letter-spacing: 4px;
      color: #007bff;
    }

    .message {
      font-size: 14px;
      color: #333;
      margin-bottom: 15px;
    }

    .footer {
      background-color: #f8f9fa;
      padding: 20px;
      border-top: 1px solid #ddd;
      font-size: 12px;
      color: #666;
      text-align: center;
    }

    .support-link {
      color: #0066cc;
      text-decoration: none;
    }

    .support-link:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="email-wrapper">
    <!-- Header -->
    <div class="email-header">
      <img src="https://proctoring-client-uploads-west.s3.us-west-2.amazonaws.com/assets/bis-logo.png" alt="Organization Logo">
    </div>

    <!-- Main Content -->
    <div class="main-content">
      <p class="greeting">
        Hello,
      </p>

      <p class="message">
        You requested a One-Time Password (OTP).
        Please use the OTP below to complete your verification. This OTP is valid for 10 minutes.
      </p>

      <!-- OTP Box -->
      <div class="otp-box">
        {{otp}}
      </div>

      <p class="message">
        If you did not request this OTP, please ignore this email.
      </p>
    </div>

    <!-- Footer -->
    <div class="footer">
      <p>
        Have a question? Contact our Support Team by phoning 1-866-416-1660 or emailing
        <a href="mailto:{{supportMail}}" class="support-link">{{supportMail}}</a>.
      </p>

      <p>
        BIS Safety Software | 261 Seneca Road, Sherwood Park AB T8A 4G6, Canada
      </p>
      <p>
        <a href="{{termsUrl}}">Terms and Conditions</a> | 
        <a href="{{privacyUrl}}">Privacy Policy</a>
      </p>

      <p>
       This email was sent to {{EmailAddress}}. This an automated message. Please do not reply to this email. 
      </p>
    </div>
  </div>
</body>
</html>
